# ===== PitchForge | 百炼路演工坊 =====
# 复制本文件为 .env 并填入真实值，.env 已在 .gitignore 中

# 服务端口
PORT=3000

# 百炼凭证（去阿里云百炼控制台获取）
# - API Key: https://bailian.console.aliyun.com → API-KEY 管理
# - 应用 ID: 创建一个"应用"（智能体/工作流）后获得
# - Region: 通常是 cn-hangzhou
BAILIAN_API_KEY=your-bailian-api-key
BAILIAN_APP_ID=your-bailian-app-id
BAILIAN_REGION=cn-hangzhou

# 模式开关：true = Mock 数据（不消耗 API 额度，方便开发演示）
#           false = 调用真实百炼 API
MOCK_MODE=false

# 限流：每 IP 15 分钟最多 30 次（防滥用）
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30
